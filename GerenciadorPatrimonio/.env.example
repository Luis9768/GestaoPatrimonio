#FORMAS DE CONEXĂO

#Conexăo com Windows Authentication
CONNECTION_STRING=Server=(localdb)\MSSQLLocalDB;Database=GestaoPatrimonios;Trusted_Connection=True; TrustServerCertificate=True

#SQL Authentication (usuario e senha)
CONNECTION_STRING=Server=(localdb)\MSSQLLocalDB;Database=GestaoPatrimonios;User ID=SEU_USUARIO;Password=SUA_SENHA;TrustServerCertificate=True

#Configuraçăo de chave JWT
#Chave precisa ter pelo menos 32 caracteres
JWT_KEY=sua_chave_aqui